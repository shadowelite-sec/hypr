
#!/bin/sh

# rofi theme
theme="$HOME/.config/rofi/config/screenshot.rasi"

get_options() {
  echo "’éā  Selected area screenshot"
  echo "’éā  Full screen screenshot"
  echo "’ōó Stop Recording"
  echo "’ĆĮ  Selected area video"
  echo "’ĆĮ  Full screen video"
  echo "’ĆĮ  Selected area video with audio (microphone)"
  echo "’ĆĮ  Full screen video with audio (microphone)"
  echo "’ĆĮ  Selected area video with audio (desktop)"
  echo "’ĆĮ  Full screen video with audio (desktop)"
  echo "’ĆĮ  Selected area video with all audio"
  echo "’ĆĮ  Full screen area video with all audio"
}

main() {

  # get choice from rofi
  choice=$( (get_options) | rofi -n -dmenu -k "/dev/null" -i -theme $theme)

  # run the selected command
  case $choice in
  '’éā  Selected area screenshot')
    $HOME/.config/rofi/bin/wscreenshot -sa
    ;;
  '’éā  Full screen screenshot')
    $HOME/.config/rofi/bin/wscreenshot -sf
    ;;
  '’ōó Stop Recording')
    $HOME/.config/rofi/bin/wscreenshot -s
    ;;
  '’ĆĮ  Selected area video')
    $HOME/.config/rofi/bin/wscreenshot -va
    ;;
  '’ĆĮ  Full screen video')
    $HOME/.config/rofi/bin/wscreenshot -vf
    ;;
  '’ĆĮ  Selected area video with audio (microphone)')
    $HOME/.config/rofi/bin/wscreenshot -vaam
    ;;
  '’ĆĮ  Full screen video with audio (microphone)')
    $HOME/.config/rofi/bin/wscreenshot -vfam
    ;;
  '’ĆĮ  Selected area video with audio (desktop)')
    $HOME/.config/rofi/bin/wscreenshot -vsad
    ;;
  '’ĆĮ  Full screen video with audio (desktop)')
    $HOME/.config/rofi/bin/wscreenshot -vfad
    ;;
  '’ĆĮ  Selected area video with all audio')
    $HOME/.config/rofi/bin/wscreenshot -vsaa
  ;;
  '’ĆĮ  Full screen area video with all audio')
    $HOME/.config/rofi/bin/wscreenshot -vfaa
  ;;
  esac
  # done
  set -e
}

main &

exit 0

