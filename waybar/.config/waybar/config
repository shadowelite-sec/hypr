{
  "include": "~/.config/waybar/configs/custom_modules/modules",
  "layer": "top",
  "height": 22,
  "margin-top": 0,
  "margin-left": 0,
  "margin-bottom": 0,
  "margin-right": 0,
  "spacing": 0,
  "modules-left": [
    "custom/launcher",
    "wlr/workspaces",
    "custom/arrow-dec",
    "custom/app-icon",
    "custom/app-name"
  ],
  "modules-center": [
    "custom/left",
    "custom/priv-cam",
    "custom/priv-speaker",
    "custom/priv-mic",
    "custom/right"
  ],
  "modules-right": [
    "memory",
    "custom/dot",
    "network",
    "custom/left-arrw",
    "tray",
    "custom/dot-alt",
    "battery",
    "battery#text",
    "custom/pacman-update",
    "custom/pacman-update#text",
    "pulseaudio",
    "pulseaudio#text",
    "custom/dot-alt",
    "clock"
  ],
  "wlr/workspaces": {
    "all-outputs": false,
    "active-only": "false",
    "on-click": "activate",
    "format": "{icon}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format-icons": {
      "1": "ґкдН",
      "2": "ґкдХ",
      "3": "ґкеМ",
      "4": "ґкеЕ",
      "5": "ґкдД",
      "6": "ґкдЛ",
      "7": "ґкдЭ",
      "8": "ґкдП",
      "urgent": "ґкд│",
      "default": "ґкд╛"
    }
  },
  "hyprland/window": {
    "format": "{}"
  },
  "tray": {
    "icon-size": 28,
    "spacing": 8
  },
  "clock": {
    "format": "<b>{:%I:%M %p}</b>",
    "format-alt": "<b>{:%a.%d,%b}</b>",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "cpu": {
    "interval": 10,
    "format": "ґкдФ {}%",
    "max-length": 10,
    "on-click": "",
    "tooltip": false
  },
  "memory": {
    "interval": 30,
    "format": "ґкд▓ {used}G",
    "format-alt": "яС▓ {used:0.1f}G",
    "max-length": 10
  },
  "backlight": {
    "device": "DP-1",
    "format": "{icon} {percent}%",
    "tooltip": false,
    "format-icons": [
      "ґкдк",
      "ґкдк",
      "ґкдк",
      "ґкдк",
      "ґкдк",
      "ґкдк",
      "ґкдк",
      "ґкдк",
      "ґкдк"
    ],
    "on-click": ""
  },
  "network": {
    "format-wifi": "ґкеИ {essid}",
    "format-ethernet": "ґкеИ wired",
    "tooltip": false,
    "format-disconnected": ""
  },
  "pulseaudio": {
    "format": "{icon}",
    "format-bluetooth": "яАе ",
    "format-bluetooth-muted": "яЪй яКФ",
    "tooltip": false,
    "format-muted": "ґ░ЦБ",
    "format-icons": {
      "headphone": "ґкеЖ",
      "hands-free": "ґкде",
      "headset": "ґкеЖ",
      "phone": "ґкде",
      "portable": "юеЖ",
      "car": "яЖ╣",
      "default": [
        "ґкдж",
        "ґкдж",
        "ґкдТ"
      ]
    },
    "on-click": "pavucontrol"
  },
  "pulseaudio#text": {
    "tooltip": false,
    "format": "<b>{volume}</b>",
    "format-bluetooth": "{volume}"
  },
  "battery": {
    "bat": "BAT1",
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}",
    "format-icons": [
      "ґкеЦ",
      "ґкеЭ",
      "ґкеЮ",
      "ґкеЮ",
      "ґкеЯ"
    ],
    "max-length": 25,
    "tooltip": false
  },
  "battery#text": {
    "bat": "BAT1",
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "<b>{capacity}</b>",
    "max-length": 25,
    "tooltip": false
  }
}
